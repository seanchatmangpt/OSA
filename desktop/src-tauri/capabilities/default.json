{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capability set for OSA Desktop.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-execute",
    "shell:allow-spawn",
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "dialog:default",
    "fs:default",
    "fs:allow-app-read-recursive",
    "fs:allow-app-write-recursive",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "notification:default",
    "os:default",
    "process:default"
  ]
}
