# LLM Providers
OSA_DEFAULT_PROVIDER=ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# Ollama Cloud — set OLLAMA_API_KEY to use Ollama Cloud instead of local Ollama
# Leave OLLAMA_URL/OLLAMA_MODEL unset to use the defaults from config.exs (Ollama Cloud + nemotron-3-super:cloud)
OLLAMA_URL=https://ollama.com
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_API_KEY=

# HTTP Port
# Default for standalone CLI/server: 8089. Set to 9089 only for Tauri embedded sidecar.
OSA_HTTP_PORT=8089

# Channels
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Web Search
BRAVE_API_KEY=
