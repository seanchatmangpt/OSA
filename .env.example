# LLM Providers
OSA_DEFAULT_PROVIDER=ollama
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GROQ_API_KEY=
# Ollama Cloud — set OLLAMA_API_KEY to use Ollama Cloud instead of local Ollama
# Leave OLLAMA_URL/OLLAMA_MODEL unset to use the defaults from config.exs (Ollama Cloud + nemotron-3-super:cloud)
OLLAMA_URL=https://ollama.com
OLLAMA_MODEL=nemotron-3-super:cloud
OLLAMA_API_KEY=

# HTTP Port
# Default: 8089 for standalone CLI/iex usage.
# Set to 9089 when running the Tauri desktop app — the app's Rust sidecar
# layer probes http://127.0.0.1:9089/health and reports "backend-unavailable"
# if nothing answers on that port.
OSA_HTTP_PORT=9089

# Channels
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# Web Search
BRAVE_API_KEY=
