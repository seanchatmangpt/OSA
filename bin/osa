#!/usr/bin/env bash
# bin/osa — One command to start OSA.
#
# Starts the Elixir backend in the background, waits for it to be healthy,
# launches the Rust TUI, and tears down the backend when you quit.
#
# Subcommands:
#   osa                    Start backend + TUI (default)
#   osa setup              Run the setup wizard
#   osa update             Pull latest, recompile, rebuild TUI
#   osa serve              Start backend only (headless HTTP API)
#   osa doctor             Run health checks
#   osa version            Print version
#   osa --dev              Dev profile + port 19001

set -euo pipefail

# ── Safe defaults ────────────────────────────────────────────────
HOME="${HOME:-/root}"
export LC_ALL="${LC_ALL:-C.UTF-8}"
export LANG="${LANG:-C.UTF-8}"

# sudo helper: skip when already root
if [ "$(id -u)" -eq 0 ]; then
  SUDO=""
else
  SUDO="sudo"
fi

# ── Colors ─────────────────────────────────────────────────────────
if [ -t 1 ]; then
  BOLD='\033[1m'
  DIM='\033[2m'
  GREEN='\033[0;32m'
  YELLOW='\033[0;33m'
  RED='\033[0;31m'
  CYAN='\033[0;36m'
  RESET='\033[0m'
else
  BOLD='' DIM='' GREEN='' YELLOW='' RED='' CYAN='' RESET=''
fi

# ── Detect package manager ───────────────────────────────────────
detect_pkg() {
  if   command -v apt-get >/dev/null 2>&1; then PKG="apt"
  elif command -v dnf     >/dev/null 2>&1; then PKG="dnf"
  elif command -v pacman  >/dev/null 2>&1; then PKG="pacman"
  elif command -v apk     >/dev/null 2>&1; then PKG="apk"
  elif command -v zypper  >/dev/null 2>&1; then PKG="zypper"
  elif command -v yum     >/dev/null 2>&1; then PKG="yum"
  elif command -v brew    >/dev/null 2>&1; then PKG="brew"
  else PKG="unknown"
  fi
}

# Package install abstraction
pkg_install() {
  case "$PKG" in
    apt)    $SUDO apt-get install -y -qq "$@" ;;
    dnf)    $SUDO dnf install -y -q "$@" ;;
    yum)    $SUDO yum install -y -q "$@" ;;
    pacman) $SUDO pacman -Sy --noconfirm "$@" ;;
    apk)    $SUDO apk add --no-cache "$@" ;;
    zypper) $SUDO zypper install -y "$@" ;;
    brew)   brew install "$@" ;;
    *)      return 1 ;;
  esac
}

# ── HTTP helper (curl → wget fallback) ───────────────────────────
_http_ok() {
  if command -v curl >/dev/null 2>&1; then
    curl -sf "$1" >/dev/null 2>&1
  elif command -v wget >/dev/null 2>&1; then
    wget -qO /dev/null "$1" 2>/dev/null
  else
    return 1
  fi
}

# Elixir version check (>= 1.17)
check_elixir_version() {
  local ver major minor
  ver=$(elixir --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' | head -1)
  [ -z "$ver" ] && return 1
  major=$(echo "$ver" | cut -d. -f1)
  minor=$(echo "$ver" | cut -d. -f2)
  [ "${major:-0}" -gt 1 ] && return 0
  [ "${major:-0}" -eq 1 ] && [ "${minor:-0}" -ge 17 ] && return 0
  return 1
}

# ── Resolve project root ──────────────────────────────────────────
SCRIPT="$0"
if [ -L "$SCRIPT" ]; then
  SCRIPT="$(readlink -f "$SCRIPT" 2>/dev/null || python3 -c "import os,sys; print(os.path.realpath(sys.argv[1]))" "$SCRIPT" 2>/dev/null || perl -e 'use Cwd "abs_path"; print abs_path(shift)' "$SCRIPT")"
fi
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT")" && pwd)"

if [ -f "$SCRIPT_DIR/../mix.exs" ]; then
  ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
elif [ -f "${HOME}/.osa/project_root" ]; then
  ROOT="$(cat "${HOME}/.osa/project_root")"
else
  echo -e "${RED}Error: Cannot find OSA project root.${RESET}"
  echo "Run the installer: curl -fsSL https://raw.githubusercontent.com/Miosa-osa/OptimalSystemAgent/main/scripts/install.sh | bash"
  exit 1
fi

TUI_DIR="$ROOT/priv/rust/tui"
TUI_BIN="$TUI_DIR/target/release/osagent"
LOG_DIR="${HOME}/.osa/logs"
BACKEND_PID=""

mkdir -p "$LOG_DIR"

# ── Subcommand dispatch ───────────────────────────────────────────
case "${1:-}" in
  version|--version|-v)
    if [ -f "$ROOT/VERSION" ]; then
      echo "osagent v$(cat "$ROOT/VERSION")"
    else
      (cd "$ROOT" && mix run -e "IO.puts(Application.spec(:optimal_system_agent, :vsn))" 2>/dev/null) || echo "osagent (version unknown)"
    fi
    exit 0
    ;;

  setup)
    echo -e "${CYAN}→${RESET} Running setup wizard..."
    (cd "$ROOT" && mix osa.setup.wizard)
    exit $?
    ;;

  update)
    echo -e "${CYAN}→${RESET} Updating OSA Agent..."
    echo -e "${DIM}  Project: $ROOT${RESET}"

    echo -e "${CYAN}→${RESET} Pulling latest..."
    (cd "$ROOT" && git pull --ff-only origin main 2>&1) || echo -e "${RED}  git pull failed — continuing anyway${RESET}"

    echo -e "${CYAN}→${RESET} Fetching dependencies..."
    (cd "$ROOT" && mix deps.get 2>&1 | tail -3)
    echo -e "${CYAN}→${RESET} Compiling (--force)..."
    (cd "$ROOT" && mix compile --force 2>&1 | tail -5)

    if [ -f "$TUI_DIR/Cargo.toml" ]; then
      echo -e "${CYAN}→${RESET} Rebuilding TUI..."
      if ! (cd "$TUI_DIR" && cargo build --release 2>&1 | grep -E "Compiling|Finished|error" | tail -5); then
        echo -e "${YELLOW}⚠${RESET} TUI rebuild had warnings — check above"
      fi
    fi

    echo ""
    echo -e "${GREEN}✓ Update complete.${RESET} Restart with: ${BOLD}osa${RESET}"
    exit 0
    ;;

  serve)
    echo -e "${CYAN}→${RESET} Starting backend (headless)..."
    (cd "$ROOT" && mix local.hex --force --if-missing >/dev/null 2>&1 || true)
    (cd "$ROOT" && mix local.rebar --force --if-missing >/dev/null 2>&1 || true)
    (cd "$ROOT" && mix deps.get --quiet 2>&1 | tail -3)
    (cd "$ROOT" && mix osa.serve)
    exit 0
    ;;

  doctor)
    (cd "$ROOT" && mix run -e "OptimalSystemAgent.CLI.doctor()" 2>/dev/null) || \
      (cd "$ROOT" && mix run -e "OptimalSystemAgent.CLI.Doctor.run()" 2>/dev/null) || \
      echo "Doctor command not available. Try: mix osa.chat then type /doctor"
    exit 0
    ;;

  help|--help|-h)
    echo ""
    echo -e "${BOLD}  OSA Agent${RESET} — Your OS, Supercharged"
    echo ""
    echo -e "  ${BOLD}Usage:${RESET}"
    echo -e "    ${CYAN}osa${RESET}              Start backend + TUI (default)"
    echo -e "    ${CYAN}osa setup${RESET}        Run the setup wizard"
    echo -e "    ${CYAN}osa update${RESET}       Pull latest, recompile, rebuild TUI"
    echo -e "    ${CYAN}osa serve${RESET}        Start backend only (headless HTTP API)"
    echo -e "    ${CYAN}osa doctor${RESET}       Run health checks"
    echo -e "    ${CYAN}osa version${RESET}      Print version"
    echo ""
    echo -e "  ${BOLD}Options:${RESET}"
    echo -e "    ${CYAN}--dev${RESET}            Dev profile (port 19001)"
    echo ""
    exit 0
    ;;
esac

# ── Default: start backend + TUI ─────────────────────────────────

cleanup() {
  if [ -n "$BACKEND_PID" ] && kill -0 "$BACKEND_PID" 2>/dev/null; then
    kill "$BACKEND_PID" 2>/dev/null
    wait "$BACKEND_PID" 2>/dev/null || true
  fi
}
trap cleanup EXIT INT TERM

detect_pkg

# ── Auto-install missing dependencies ────────────────────────────

# Install native build deps for Rust TUI on Linux
install_linux_build_deps() {
  [ "$(uname -s)" = "Linux" ] || return 0
  # Quick check: if TUI binary already exists, skip
  [ -f "$TUI_BIN" ] && return 0

  echo -e "${CYAN}→${RESET} Checking build dependencies..."
  case "$PKG" in
    apt)
      local needed=()
      command -v pkg-config >/dev/null 2>&1 || needed+=(pkg-config)
      command -v gcc >/dev/null 2>&1        || needed+=(build-essential)
      [ -f /usr/lib/*/libssl.so ] 2>/dev/null || [ -f /usr/lib/*/libssl.a ] 2>/dev/null || needed+=(libssl-dev)
      [ -f /usr/lib/*/libxcb.so ] 2>/dev/null || [ -f /usr/lib/*/libxcb.a ] 2>/dev/null || needed+=(libxcb1-dev libxcb-render0-dev libxcb-shape0-dev libxcb-xfixes0-dev)
      [ -f /usr/lib/*/libasound.so ] 2>/dev/null || [ -f /usr/lib/*/libasound.a ] 2>/dev/null || needed+=(libasound2-dev)
      [ -f /usr/lib/*/libonig.so ] 2>/dev/null || [ -f /usr/lib/*/libonig.a ] 2>/dev/null || needed+=(libonig-dev)
      if [ ${#needed[@]} -gt 0 ]; then
        echo -e "${CYAN}→${RESET} Installing: ${needed[*]}..."
        $SUDO apt-get update -qq 2>/dev/null || true
        $SUDO apt-get install -y -qq "${needed[@]}" 2>/dev/null || true
      fi
      ;;
    dnf|yum)
      pkg_install gcc gcc-c++ make pkg-config openssl-devel libxcb-devel alsa-lib-devel oniguruma-devel 2>/dev/null || true
      ;;
    pacman)
      pkg_install base-devel pkg-config openssl libxcb alsa-lib oniguruma 2>/dev/null || true
      ;;
    apk)
      pkg_install build-base pkgconfig openssl-dev libxcb-dev alsa-lib-dev oniguruma-dev 2>/dev/null || true
      ;;
    zypper)
      pkg_install gcc gcc-c++ make pkg-config libopenssl-devel libxcb-devel alsa-devel oniguruma-devel 2>/dev/null || true
      ;;
  esac
}

# Auto-install Rust if missing
if ! command -v cargo >/dev/null 2>&1; then
  echo -e "${CYAN}→${RESET} Rust not found — installing automatically..."
  if command -v curl >/dev/null 2>&1; then
    curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --quiet
  elif command -v wget >/dev/null 2>&1; then
    wget -qO- https://sh.rustup.rs | sh -s -- -y --quiet
  else
    echo -e "${RED}✗ Neither curl nor wget found.${RESET}"
    echo -e "${DIM}  Falling back to CLI mode.${RESET}"
    (cd "$ROOT" && mix osa.chat)
    exit $?
  fi
  . "${HOME}/.cargo/env" 2>/dev/null || true
  export PATH="${HOME}/.cargo/bin:$PATH"
  if ! command -v cargo >/dev/null 2>&1; then
    echo -e "${RED}✗ Rust installation failed.${RESET} Install manually: https://rustup.rs"
    echo -e "${DIM}  Falling back to CLI mode.${RESET}"
    (cd "$ROOT" && mix osa.chat)
    exit $?
  fi
  echo -e "${GREEN}✓${RESET} Rust installed"
fi

# Auto-install Elixir if missing or too old
install_elixir_prebuilt() {
  local elixir_ver="1.18.3"
  local otp_major
  otp_major=$(erl -eval 'io:format("~s", [erlang:system_info(otp_release)]), halt().' -noshell 2>/dev/null || echo "27")
  local url="https://github.com/elixir-lang/elixir/releases/download/v${elixir_ver}/elixir-otp-${otp_major}.zip"
  echo -e "${CYAN}→${RESET} Installing Elixir ${elixir_ver} from prebuilt..."
  local dest="/usr/local/lib/elixir"
  $SUDO mkdir -p "$dest"
  command -v unzip >/dev/null 2>&1 || pkg_install unzip 2>/dev/null || true
  if curl -fsSLo /tmp/elixir.zip "$url" 2>/dev/null; then
    $SUDO unzip -qo /tmp/elixir.zip -d "$dest"
    rm -f /tmp/elixir.zip
    for bin in elixir mix iex elixirc; do
      $SUDO ln -sf "$dest/bin/$bin" /usr/local/bin/"$bin"
    done
    echo -e "${GREEN}✓${RESET} Elixir ${elixir_ver} installed"
  else
    echo -e "${RED}✗ Could not download Elixir prebuilt.${RESET}"
    return 1
  fi
}

if ! command -v mix >/dev/null 2>&1; then
  echo -e "${CYAN}→${RESET} Elixir not found — installing automatically..."
  case "$(uname -s)" in
    Darwin)
      if ! command -v brew >/dev/null 2>&1; then
        echo -e "${CYAN}→${RESET} Installing Homebrew first..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [ -f "/opt/homebrew/bin/brew" ]; then
          eval "$(/opt/homebrew/bin/brew shellenv)"
        elif [ -f "/usr/local/bin/brew" ]; then
          eval "$(/usr/local/bin/brew shellenv)"
        fi
      fi
      brew install erlang elixir
      ;;
    Linux)
      # Install Erlang from system packages
      case "$PKG" in
        apt) $SUDO apt-get update -qq; pkg_install erlang 2>/dev/null || true ;;
        dnf|yum) pkg_install epel-release 2>/dev/null || true; pkg_install erlang 2>/dev/null || true ;;
        pacman) pkg_install erlang 2>/dev/null || true ;;
        apk) pkg_install erlang 2>/dev/null || true ;;
        zypper) pkg_install erlang 2>/dev/null || true ;;
      esac
      # Try system Elixir, then prebuilt if version is wrong
      pkg_install elixir 2>/dev/null || true
      if ! command -v mix >/dev/null 2>&1 || ! check_elixir_version; then
        install_elixir_prebuilt || {
          echo -e "${RED}✗ Cannot install Elixir.${RESET}"
          exit 1
        }
      fi
      ;;
  esac
  if ! command -v mix >/dev/null 2>&1; then
    echo -e "${RED}✗ Elixir installation failed.${RESET}"
    exit 1
  fi
  echo -e "${GREEN}✓${RESET} Elixir ready"
  # First-time setup
  echo -e "${CYAN}→${RESET} Fetching dependencies..."
  (cd "$ROOT" && mix local.hex --force --if-missing >/dev/null 2>&1 || true)
  (cd "$ROOT" && mix local.rebar --force --if-missing >/dev/null 2>&1 || true)
  (cd "$ROOT" && mix deps.get 2>&1 | tail -5)
  (cd "$ROOT" && mix compile 2>&1 | tail -5)
elif ! check_elixir_version; then
  echo -e "${YELLOW}⚠${RESET} Elixir version too old (need 1.17+). Upgrading..."
  install_elixir_prebuilt || echo -e "${RED}✗ Could not upgrade Elixir.${RESET}"
fi

# Install Linux build deps before Rust build
install_linux_build_deps

# Build Rust TUI if needed
if [ ! -f "$TUI_BIN" ]; then
  if [ -f "$TUI_DIR/Cargo.toml" ]; then
    echo -e "${CYAN}→${RESET} Building TUI (first run, ~60s)..."
    (cd "$TUI_DIR" && cargo build --release 2>&1 | tail -10)
    if [ ! -f "$TUI_BIN" ]; then
      echo -e "${RED}✗ TUI build failed.${RESET} Falling back to CLI mode."
      echo -e "${DIM}  Check: cargo, rustc installed? Run: rustup update${RESET}"
      (cd "$ROOT" && mix osa.chat)
      exit $?
    fi
  else
    echo -e "${RED}✗ TUI source not found.${RESET} Falling back to CLI mode."
    (cd "$ROOT" && mix osa.chat)
    exit $?
  fi
fi

# Ensure Elixir deps are compiled
if [ ! -d "$ROOT/_build" ]; then
  echo -e "${CYAN}→${RESET} First-time compile..."
  (cd "$ROOT" && mix local.hex --force --if-missing >/dev/null 2>&1 || true)
  (cd "$ROOT" && mix local.rebar --force --if-missing >/dev/null 2>&1 || true)
  (cd "$ROOT" && mix deps.get 2>&1 | tail -5)
  (cd "$ROOT" && mix compile 2>&1 | tail -5)
fi

# Auto-enable computer_use on Linux X11
if [ "$(uname -s)" = "Linux" ] && [ -n "${DISPLAY:-}" ]; then
  export OSA_COMPUTER_USE="${OSA_COMPUTER_USE:-true}"
fi

# Determine port (strip --dev from args passed to TUI)
PORT="${OSA_PORT:-8089}"
TUI_ARGS=()
for arg in "$@"; do
  if [ "$arg" = "--dev" ]; then
    PORT="${OSA_PORT:-19001}"
  else
    TUI_ARGS+=("$arg")
  fi
done

# Check if backend is already running
URL="http://localhost:${PORT}/health"
if _http_ok "$URL"; then
  echo -e "${DIM}Backend already running on :${PORT}${RESET}"
else
  # Kill anything on our port
  if command -v lsof >/dev/null 2>&1 && lsof -i ":${PORT}" -sTCP:LISTEN >/dev/null 2>&1; then
    echo -e "${DIM}Port ${PORT} in use. Killing previous instance…${RESET}"
    lsof -ti ":${PORT}" -sTCP:LISTEN | xargs kill -9 2>/dev/null || true
    sleep 1
  elif command -v fuser >/dev/null 2>&1; then
    fuser -k "${PORT}/tcp" 2>/dev/null || true
    sleep 1
  elif command -v ss >/dev/null 2>&1; then
    # Last resort: check with ss
    if ss -tlnp 2>/dev/null | grep -q ":${PORT} "; then
      echo -e "${YELLOW}⚠${RESET} Port ${PORT} in use but cannot kill (no lsof/fuser). May fail to start."
    fi
  fi

  export MIX_ENV="${MIX_ENV:-dev}"
  LOG_FILE="$LOG_DIR/backend.log"
  : > "$LOG_FILE"
  echo -e "${CYAN}→${RESET} Starting backend on :${PORT}..."

  if [[ "$OSTYPE" == "msys" || "$OSTYPE" == "cygwin" || "$OSTYPE" == "win32" ]]; then
    (cd "$ROOT" && elixir --no-halt \
      -e "Application.put_env(:elixir, :ansi_enabled, false)" \
      -S mix osa.serve) </dev/null >"$LOG_FILE" 2>&1 &
  else
    (cd "$ROOT" && mix osa.serve) >"$LOG_FILE" 2>&1 &
  fi
  BACKEND_PID=$!
fi

# Wait for health (90s for cold compile on slow VPS)
attempts=0
max_attempts=90

while [ $attempts -lt $max_attempts ]; do
  if _http_ok "$URL"; then
    break
  fi
  if [ -n "$BACKEND_PID" ] && ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo -e "${RED}✗ Backend process exited unexpectedly.${RESET}"
    echo "  Last log lines:"
    tail -15 "$LOG_DIR/backend.log" 2>/dev/null | sed 's/^/    /'
    exit 1
  fi
  attempts=$((attempts + 1))
  sleep 1
done

if [ $attempts -eq $max_attempts ]; then
  echo -e "${RED}✗ Backend did not become healthy after ${max_attempts}s.${RESET}"
  echo "  Last log lines:"
  tail -15 "$LOG_DIR/backend.log" 2>/dev/null | sed 's/^/    /'
  exit 1
fi

# First-run: if no ~/.osa/.env exists, run the setup wizard
if [ ! -f "$HOME/.osa/.env" ]; then
  echo -e "${CYAN}→${RESET} First-time setup..."
  (cd "$ROOT" && mix osa.setup.wizard)
  wizard_exit=$?

  if [ $wizard_exit -ne 0 ]; then
    echo -e "${YELLOW}⚠${RESET} Setup skipped. Run 'osa setup' later to configure."
  fi
fi

# Launch TUI
export OSA_URL="http://localhost:${PORT}"
exec "$TUI_BIN" ${TUI_ARGS[@]+"${TUI_ARGS[@]}"}
